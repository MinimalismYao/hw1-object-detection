# ============================
# Git Ignore for HW1 - Object Detection
# ============================

# ---- Python 自動產生的快取檔，不需要版本控制 ----
__pycache__/
*.pyc
*.pyo
*.pyd

# ---- 虛擬環境 (conda/venv)，每個人環境不同，不應上傳 ----
.venv/
env/
venv/

# ---- Dataset (Kaggle 下載)，檔案太大，請助教自行下載即可 ----
data/train/
data/test/
data/mini_test/
data/*.zip
data/val

# ---- 訓練與驗證 log (tensorboard, checkpoint)，檔案通常很大 ----
experiments/logs/
runs/
checkpoints/
vis_gt/

# ---- 系統相關檔案 (避免 Mac / Windows 雜檔被推上去) ----
.DS_Store
Thumbs.db

# ---- Jupyter Notebook 的自動檔案 (如果有使用) ----
.ipynb_checkpoints/
