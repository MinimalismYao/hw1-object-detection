{
  "seed": 42,
  "project": {
    "name": "hw1_od",
    "seed": 42,
    "run_name": "fasterrcnn_v6",
    "output_root": "experiments/logszrer",
    "output_dir": "experiments/logszrer/fasterrcnn_v6"
  },
  "data": {
    "root": "data",
    "train_img_dir": "data/train/img",
    "train_gt": "data/train/gt_train.txt",
    "val_img_dir": "data/val/img",
    "val_gt": "data/val/gt_val.txt",
    "test_img_dir": "data/test/img",
    "num_workers": 16,
    "allow_float_bbox": true,
    "clip_bbox_to_image": true,
    "drop_invalid_bbox": true,
    "min_box_wh": [
      1,
      1
    ]
  },
  "model": {
    "detector": "fasterrcnn_r50_fpn",
    "backbone": "resnet50",
    "num_classes": 2,
    "pretrained_backbone": false,
    "freeze_backbone": false,
    "min_size": 1536,
    "max_size": 1536,
    "rpn_anchor_sizes": [
      [
        16
      ],
      [
        32
      ],
      [
        64
      ],
      [
        128
      ],
      [
        512
      ]
    ],
    "rpn_anchor_ratios": [
      0.33,
      0.5,
      1.0,
      2.0,
      3.0
    ],
    "rpn_batch_size_per_image": 512,
    "rpn_positive_fraction": 0.5,
    "rpn_fg_iou_thresh": 0.6,
    "rpn_bg_iou_thresh": 0.2,
    "rpn_pre_nms_top_n_train": 4000,
    "rpn_post_nms_top_n_train": 2000,
    "rpn_pre_nms_top_n_test": 2000,
    "rpn_post_nms_top_n_test": 1000,
    "rpn_nms_thresh": 0.7,
    "box_batch_size_per_image": 1024,
    "box_positive_fraction": 0.5,
    "box_score_thresh": 0.02,
    "box_nms_thresh": 0.6,
    "box_detections_per_img": 300
  },
  "augment": {
    "mosaic": false,
    "mixup": false,
    "cutout": false,
    "blur_p": 0.0,
    "noise_p": 0.0,
    "sharpen_p": 0.0,
    "affine_p": 0.0,
    "perspective_p": 0.0,
    "resize": [
      896,
      1024,
      1200,
      1400
    ],
    "max_side": 1536,
    "flip_p": 0.5,
    "hsv": [
      0.015,
      0.7,
      0.4
    ],
    "color_jitter_prob": 0.8,
    "color_jitter": [
      0.2,
      0.2,
      0.2,
      0.05
    ],
    "random_crop_prob": 0.2,
    "random_crop_min_iou": 0.5,
    "gaussian_blur_prob": 0.1,
    "gaussian_blur_sigma": [
      0.1,
      1.0
    ],
    "random_noise_prob": 0.1,
    "normalize_mean_std": [
      [
        0.485,
        0.456,
        0.406
      ],
      [
        0.229,
        0.224,
        0.225
      ]
    ]
  },
  "train": {
    "epochs": 50,
    "batch_size": 4,
    "grad_clip": 10.0,
    "amp": true,
    "cudnn_benchmark": true,
    "accumulate": 4,
    "sampler": {
      "enabled": false,
      "strategy": "area_weighted",
      "small_quantile": 0.15,
      "large_quantile": 0.85,
      "small_weight": 2.0,
      "large_weight": 1.5,
      "normal_weight": 1.0,
      "cache_path": "experiments/logszrer/fasterrcnn_v6/train_sampler_weights.npy"
    }
  },
  "optimizer": {
    "type": "sgd",
    "lr": 0.01,
    "momentum": 0.9,
    "weight_decay": 0.0005
  },
  "scheduler": {
    "type": "steplr",
    "step_size": 8,
    "gamma": 0.1
  },
  "dataloader": {
    "pin_memory": true,
    "persistent_workers": true,
    "prefetch_factor": 4,
    "shuffle": true
  },
  "sanity_check": {
    "enabled": true,
    "batch_size": 1,
    "max_side": 640
  },
  "checkpoint": {
    "dir": "experiments/logszrer/fasterrcnn_v6",
    "name": "fasterrcnn_v6.pth",
    "save_last_only": true,
    "save_full_path": "experiments/logszrer/fasterrcnn_v6/fasterrcnn_v6.pth"
  },
  "logging": {
    "csv_name": "train_log.csv",
    "csv_path": "experiments/logszrer/fasterrcnn_v6/train_log.csv",
    "print_interval": 10
  },
  "eval": {
    "iou_thresholds": [
      0.5,
      0.55,
      0.6,
      0.65,
      0.7,
      0.75,
      0.8,
      0.85,
      0.9,
      0.95
    ],
    "max_det": 300,
    "save_dir": "experiments/eval_results",
    "result_txt": "experiments/eval_results/fasterrcnn_v6_results.txt",
    "result_json": "experiments/eval_results/fasterrcnn_v6_details.json",
    "breakdown_by_area": true,
    "area_ranges": {
      "small": [
        0,
        1024
      ],
      "medium": [
        1024,
        9216
      ],
      "large": [
        9216,
        "1e10"
      ]
    }
  },
  "infer": {
    "score_thr": 0.02,
    "nms_iou": 0.6,
    "submission_csv": "submissions/fasterrcnn_v6_submission.csv",
    "postproc": {
      "soft_nms": {
        "enabled": true,
        "method": "gaussian",
        "sigma": 0.5,
        "iou_thresh": 0.6,
        "score_thresh": 0.0
      },
      "area_aware_score": {
        "enabled": true,
        "small_thr": 0.02,
        "medium_thr": 0.04,
        "large_thr": 0.06,
        "small_area": 1024,
        "large_area": 9216
      },
      "topk_per_image": 300,
      "temperature_scaling": {
        "enabled": false,
        "T": 1.0
      }
    }
  },
  "device": {
    "cuda": true
  },
  "early_stop": {
    "enabled": true,
    "monitor": "val_loss",
    "mode": "min",
    "patience": 6,
    "save_best": true,
    "best_name": "fasterrcnn_v6_best.pth"
  }
}